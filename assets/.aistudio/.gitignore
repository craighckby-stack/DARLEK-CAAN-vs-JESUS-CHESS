# .gitignore for assets/.aistudio/
# DARLEK CANN v3.0 - SUPREME CODE EVOLUTION CONTROLLER
# ARCHITECTURAL BLUEPRINT: AI Studio Workspace Isolation

# 1. ENVIRONMENT & SECRETS (CRITICAL LEAK PREVENTION)
.env*
!.env.example
*.local
*.secret

# 2. IDE & OS ARTIFACTS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# 3. BUILD & DEPENDENCY ARTIFACTS
node_modules/
dist/
build/
out/
.next/
.tsbuildinfo

# 4. AI/ML EPHEMERAL DATA (Siphoned from SN: OMEGA & unitary-core)
# Exclude binary weights and large training sets while maintaining schema definitions
*.ckpt
*.pth
*.pt
*.h5
*.onnx
*.tf
*.keras
*.pb
models/checkpoints/
models/binaries/

# 5. WORKFLOW & EXPERIMENTATION LOGS
logs/
runs/
tensorboard/
output/
results/
artifacts/
__pycache__/
.cache/

# 6. DATABASE & VECTOR STORE PERSISTENCE
# Essential for epistemic_debate_engine state persistence
*.sqlite
*.sqlite-journal
*.db
*.vectorstore

# 7. JUPYTER & NOTEBOOK ARTIFACTS
.ipynb_checkpoints/

# 8. EXPLICIT TRACKING OVERRIDE
# Ensure architectural blueprints and interface schemas remain tracked
!/schemas/**/*.json
!/agent_definitions/**/*.yaml
!/prompts/**/*.md
!/workflows/**/*.json